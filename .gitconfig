[core]
	excludesfile = ~/.gitignore_global
	editor = windsurf --wait --disable-extensions
	ignorecase = false
	autocrlf = input
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[push]
    autoSetupRemote = true
[includeIf "gitdir:~/"]
    path = ~/.gitconfig-ivan
[includeIf "gitdir:~/Developer/**"]
    path = ~/.gitconfig-ivan
